    "@xyflow/react": "^12.10.1",
    "d3-force": "^3.0.0",
    "fast-xml-parser": "^5.9.3",
    "linkedom": "^0.18.13",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.2.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/d3-force": "^3.0.10",
    "@types/mozilla-readability": "^0.2.1",
