{
  "name": "aispacex",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173 --strictPort",
    "dev:ui": "cross-env VITE_API_TARGET=off vite --port 5173 --strictPort",
    "dev:vercel": "node scripts/dev.mjs",
    "dev:web": "cross-env VITE_API_TARGET=http://localhost:3000 vite --port 5173 --strictPort",
    "dev:api": "vercel dev --listen 3000",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@emoji-mart/data": "^1.2.1",
