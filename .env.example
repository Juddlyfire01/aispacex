# X (Twitter) OAuth 2.0 — Intel → Profile tab (connect your own account)
#
# Create an app at https://developer.x.com → User authentication settings:
#   - Type of App: Web App (confidential) or Native/SPA (public, PKCE only)
#   - App permissions: Read
#   - Callback URI / Redirect URL: see below — one per origin you use
#
# Set X_CLIENT_ID (and X_CLIENT_SECRET if confidential) in:
#   - Project-root `.env` for local `npm run dev` (required — in-process API
#     does not auto-pull Vercel secrets)
#   - Vercel → Project → Settings → Environment Variables
#     (enable for Preview + Production + Development)

# ——— Venice inference: front a shared key (app owner pays for everyone) ———
#
# Set BOTH to have the app power all Venice API calls from one server-side key,
# so users don't need to bring their own. The key is NEVER exposed to the
# browser — it is injected by api/venice/proxy.ts (vercel dev + Vercel deploy).
# With `npm run dev`, vercel dev pulls VENICE_API_KEY from the linked Vercel
# project when it is not set in a local .env file.
#
# VENICE_API_KEY  — server-only secret. DO NOT prefix with VITE_ (that would
#                   inline it into the client bundle for anyone to steal).
#                   Set in Vercel → Env Vars (Production + Preview + Development).
#                   Optional in local .env if the project is linked and vercel
#                   dev supplies it.
# VITE_VENICE_SERVER_FRONTED=true — client-visible flag that switches the UI to
#                   fronted mode (hides the "Connect API key" pill, routes
#                   calls to /api/venice/proxy). Must be present for the Vite
#                   process (local .env or `vercel env pull`). Unset for BYOK.
VENICE_API_KEY=
VITE_VENICE_SERVER_FRONTED=true

# OAuth 2.0 Client ID from the X developer portal (required)
X_CLIENT_ID=

# OAuth 2.0 Client Secret. REQUIRED for a confidential ("Web App") client.
# Leave BLANK for a public client (PKCE-only, no secret).
X_CLIENT_SECRET=

# App-only bearer token (Read) — powers the gratis @AskVenice demo in Intel → Others
# when the visitor has not connected their own X account. Create in the X developer
# portal → Keys and tokens → Bearer Token. Set in Vercel (Production + Preview)
# and in local `.env` for `vercel dev`. Never prefix with VITE_.
X_BEARER_TOKEN=

# ——— x402 credits (USDC on Base) ———
#
# Topology: shared VENICE_API_KEY / X_BEARER_TOKEN still pay Venice + X.
# x402 is the monetization layer on top — users top up USDC to YOUR wallet,
# get an internal credit balance, and actions debit (raw API cost × margin).
#
# How "paid" works (no separate UI toggle):
#   VITE_X402_ENABLED=false  → feature hidden; everyone on Free / BYOK
#   VITE_X402_ENABLED=true   → Credits UI appears; Free still works until a
#                              wallet is connected. Connect = paid. Disconnect = Free.
# There is NO env that forces paid-only or disables Free entirely.
#
# --- Client (VITE_ = browser-visible; never put secrets here) ---
#
# VITE_X402_ENABLED=true
#   Master switch for the Credits feature in the UI.
#   true  = show Connect wallet / Billing / balance; users opt into paid by
#           connecting. No wallet ⇒ Free / BYOK unchanged.
#   false = hide all of that; app behaves as Free/BYOK only.
#
# VITE_X402_RECEIVER_WALLET=0x…
#   Your collection wallet on Base (public). User USDC top-ups are sent here.
#   Must match what the server trusts (X402_RECEIVER_WALLET / same VITE_ value).
#
# VITE_X402_MARGIN=1.3
#   Multiplier on raw itemized API cost when debiting credits.
#   chargedUsd = rawCostUsd × margin. Default 1.3 (30% margin).
#
# VITE_X402_PASS_X_DEDUP=true
#   Pass X's daily resource dedup through to metering/charges.
#   true  = same post/user ID billed at most once per UTC day (cheaper refreshes).
#   false = bill every result_count; dedup savings stay in your margin.
#   Owned-Read discount is still retained as margin either way.
#
# VITE_X402_MIN_TOPUP_USD=5
#   Minimum USDC top-up in the Purchase UI. Default 5.
#
# --- Server only (never VITE_ — used by api/x402/*) ---
#
# X402_RECEIVER_WALLET=0x…     Collection address (server may fall back to VITE_).
# X402_MIN_TOPUP_USD=5         Server-side minimum (may fall back to VITE_).
# X402_MARGIN=1.3              Server debit margin (may fall back to VITE_).
# X402_SESSION_SECRET=…        HMAC secret for short-lived tokens after SIWE.
#                              Unset → random per boot (tokens die on redeploy).
# X402_FACILITATOR_URL=        Optional x402 facilitator settle URL (advanced).
# X402_SETTLEMENT_PRIVATE_KEY= Optional settlement key (advanced; usually unset).
# X402_X_UNIT_PRICE_USD=0.005  Assumed $/X-resource for daily reconcile cron.
# VENICE_ADMIN_KEY=            Venice ADMIN key for reconcile analytics
#                              (falls back to VENICE_API_KEY if it has ADMIN scope).
# CRON_SECRET=                 Auth for Vercel Cron → /api/x402/reconcile.
# BASE_RPC_URL=https://mainnet.base.org
#                              RPC to verify on-chain USDC top-up txs.
# KV_* / Upstash Redis         Required to store credit balances + ledger.
#
# VITE_X402_ENABLED=
# VITE_X402_RECEIVER_WALLET=
# VITE_X402_MARGIN=1.3
# VITE_X402_PASS_X_DEDUP=
# VITE_X402_MIN_TOPUP_USD=5

# ——— OAuth URLs (usually leave unset) ———
#
# By default the server derives redirect + bounce URLs from the browser Host
# header (works for localhost:5173, vercel dev, production, and previews).
# Only set these if you need a fixed override (set X_OAUTH_USE_ENV_URLS=true).
#
# X_REDIRECT_URI=https://your-domain.com/api/x/oauth/callback
# APP_BASE_URL=https://your-domain.com/
# X_OAUTH_USE_ENV_URLS=true

# ——— Local dev ———
#
#   npm run dev
#     → Vite UI on http://localhost:5173  (your localStorage / profiles)
#     → vercel dev API on http://localhost:3000 (proxied via Vite /api)
#
# Register this callback in the X developer portal:
#   http://localhost:5173/api/x/oauth/callback
#
# Escape hatches: npm run dev:web | npm run dev:api
